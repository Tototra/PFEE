# ============================================================================
# Coach IA GTB — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles. NE JAMAIS commit .env.
# ============================================================================

# -------- Application --------
ENV=dev                              # dev | staging | prod
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# -------- Base de données (Postgres + TimescaleDB) --------
POSTGRES_USER=coachia
POSTGRES_PASSWORD=changeme
POSTGRES_DB=coachia
DATABASE_URL=postgresql+asyncpg://coachia:changeme@postgres:5432/coachia

# -------- Cache / queue --------
REDIS_URL=redis://redis:6379/0

# -------- LLM : Anthropic / Claude (principal) --------
# Laisser vide pour le POC (le proxy Anthropic interne prend le relais)
# En prod sur OVH : générer une clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2

# -------- LLM : Mistral (fallback — activer quand la clé sera disponible) --------
MISTRAL_API_KEY=                     # https://console.mistral.ai
MISTRAL_MODEL=mistral-large-latest

# -------- LLM : Gemini (fallback secondaire) --------
GEMINI_API_KEY=                      # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-1.5-pro

# -------- RAG / Embeddings --------
CHROMA_PERSIST_DIR=/app/data/chroma
EMBEDDING_MODEL=BAAI/bge-m3
RAG_TOP_K=5

# -------- Connecteur Niagara (C1) --------
# Pour le POC, point vers la station de démo AER
NIAGARA_BASE_URL=https://niagara-demo.aer.local
NIAGARA_USERNAME=
NIAGARA_PASSWORD=
NIAGARA_VERIFY_SSL=false             # true en prod après mise en place certif
NIAGARA_POLL_INTERVAL_SEC=60

# -------- Météo (Open-Meteo, sans clé) --------
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
DEFAULT_SITE_LAT=48.8566             # Paris par défaut, override par site
DEFAULT_SITE_LON=2.3522

# -------- CORS --------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -------- Hébergement OVH (prod uniquement) --------
# OVH_PROJECT_ID=
# OVH_REGION=GRA9
# OVH_API_ENDPOINT=ovh-eu
